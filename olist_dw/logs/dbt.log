  create view "postgres"."analytics"."int_seller_performance__dbt_tmp"
    
    
  as (
    SELECT 
    seller_id,
    COUNT(DISTINCT order_id) AS total_order_count,
    SUM(payment_value) AS total_revenue,
    AVG(review_score) AS average_review_score,
    COUNT(CASE WHEN is_late_delivery THEN 1 END)::FLOAT / NULLIF(COUNT(order_id), 0) AS late_delivery_rate
FROM "postgres"."analytics"."int_orders_enriched"
WHERE seller_id IS NOT NULL
GROUP BY seller_id
  );
[0m13:07:34.032000 [debug] [Thread-2 (]: SQL status: BEGIN in 0.0 seconds
